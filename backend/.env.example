# ── Database ─────────────────────────────────────────────
# Local PostgreSQL 17
DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/hotspotx?schema=public"

# ── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ── Network control (Omada + MikroTik) ───────────────────
# When true, the captive-portal flow grants access WITHOUT contacting real
# hardware (great for local dev/testing). Set to false in production.
NETWORK_SIMULATE=true

# Omada Controller v6
OMADA_BASE_URL="https://localhost:8043"
OMADA_CONTROLLER_ID=""
OMADA_OPERATOR_USER="hotspotx"
OMADA_OPERATOR_PASS="changeme"
OMADA_VERIFY_SSL=false

# MikroTik RouterOS (per-AP creds are stored on the AccessPoint record;
# these are only example defaults for local testing)
MIKROTIK_DEFAULT_PORT=8728

# ── Payments (Snippe mobile money: M-Pesa, Airtel, Mixx by Yas, Halotel) ──
# Swappable adapter: snippe | (future: azampay, clickpesa, selcom)
PAYMENT_PROVIDER="snippe"
# When true, "create payment" is faked (no real Snippe call). Webhook
# signature verification stays real. Set false in production.
PAYMENT_SIMULATE=true
SNIPPE_BASE_URL="https://api.snippe.sh"
SNIPPE_API_KEY=""
SNIPPE_WEBHOOK_SECRET="change-me-hmac-secret"
# Public base URL of THIS backend (Snippe posts the webhook here). For local
# webhook testing use your ngrok URL, e.g. https://abc123.ngrok-free.app
APP_BASE_URL="http://localhost:5000"

# ── SMS (swappable) ──────────────────────────────────────
# Swappable adapter: africastalking
SMS_PROVIDER="africastalking"
SMS_API_KEY=""
SMS_USERNAME=""
SMS_SENDER_ID="HotspotX"

# ── Frontend ─────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"
