# ── Database ─────────────────────────────────────────────
# Local PostgreSQL 17
DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/hotspotx?schema=public"

# ── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ── Omada Controller ─────────────────────────────────────
OMADA_BASE_URL="https://localhost:8043"
OMADA_CONTROLLER_ID=""
OMADA_OPERATOR_USER=""
OMADA_OPERATOR_PASS=""
OMADA_VERIFY_SSL=false

# ── Payments (mobile money aggregator) ───────────────────
# Swappable adapter: azampay | clickpesa | selcom
PAYMENT_PROVIDER="azampay"
PAYMENT_BASE_URL=""
PAYMENT_APP_NAME=""
PAYMENT_CLIENT_ID=""
PAYMENT_CLIENT_SECRET=""
PAYMENT_WEBHOOK_SECRET="change-me-hmac-secret"

# ── SMS (swappable) ──────────────────────────────────────
# Swappable adapter: africastalking
SMS_PROVIDER="africastalking"
SMS_API_KEY=""
SMS_USERNAME=""
SMS_SENDER_ID="HotspotX"

# ── Frontend ─────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"
